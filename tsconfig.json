{
	"compilerOptions": {
		"emitDeclarationOnly": false,
		"target": "ES6",
		"module": "ESNext",
		"moduleResolution": "node",
		"strict": true,
		"esModuleInterop": true,
		"sourceMap": true,
		"lib": ["ES2019", "DOM"],
		"types": []
	},
	"include": ["src"],
	"exclude": ["src/**/*.test.ts", "src/**/tests/**/*.ts"]
}
